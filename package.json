{
	"name": "playwright-page-object",
	"version": "1.4.2",
	"description": "Typed, decorator-driven Page Object Model for Playwright. Reusable, lazy locator chains in plain TypeScript classes.",
	"license": "MIT",
	"type": "commonjs",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.ts --format cjs,esm --dts --clean",
		"dev": "npm run build -- --watch",
		"lint": "biome check src",
		"lint:fix": "biome check --write src",
		"pack:example": "node ./run/pack-example-package.mjs",
		"prepare": "husky",
		"typecheck": "tsc --noEmit && cd example && tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:example": "npm run pack:example && concurrently \"cd example && npm install --force ../playwright-page-object.tgz\" \"npx playwright install --with-deps chromium\" && cd example && npm run test:e2e"
	},
	"keywords": [
		"playwright",
		"page-object",
		"page-object-model",
		"pom",
		"typescript",
		"decorators",
		"selectors",
		"locators",
		"e2e",
		"e2e-testing",
		"test-automation",
		"testing",
		"qa"
	],
	"author": {
		"name": "Sergei Shmakov",
		"url": "https://github.com/sergeyshmakov"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sergeyshmakov/playwright-page-object.git"
	},
	"bugs": {
		"url": "https://github.com/sergeyshmakov/playwright-page-object/issues"
	},
	"homepage": "https://sergeyshmakov.github.io/playwright-page-object/",
	"release": {
		"branches": [
			"main"
		],
		"plugins": [
			"@semantic-release/commit-analyzer",
			"@semantic-release/release-notes-generator",
			[
				"@semantic-release/changelog",
				{
					"changelogFile": "CHANGELOG.md"
				}
			],
			"@semantic-release/npm",
			[
				"@semantic-release/git",
				{
					"assets": [
						"package.json",
						"package-lock.json",
						"CHANGELOG.md"
					],
					"message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
				}
			],
			"@semantic-release/github"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@playwright/test": "^1.60.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@types/node": "^22.19.19",
		"concurrently": "^9.1.2",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.4",
		"semantic-release": "^25.0.3",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "~4.0.18"
	},
	"peerDependencies": {
		"@playwright/test": ">=1.35.0",
		"typescript": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"volta": {
		"node": "24.14.0"
	}
}
